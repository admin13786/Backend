# Crawl service private configuration
# Shared OSS / DashScope settings should stay in ../WorkShop/.env

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_news

# Shared SQLite path for crawler / api / monitor
AI_NEWS_DB_PATH=/app/db/ai_news.db

# uni-push 2.0 bridge configuration
# Deploy the uniCloud URLized function first, then fill these values.
UNIPUSH_HTTP_ENDPOINT=
UNIPUSH_HTTP_AUTH_TOKEN=
UNIPUSH_HTTP_TIMEOUT=20
UNIPUSH_DEFAULT_ROUTE=/pages/news-brief/issue
UNIPUSH_DAILY_TITLE=今日 AI 资讯已更新
UNIPUSH_DAILY_BODY=你关注的 AI 热点已更新，点击查看今天的精选资讯。

# Selected issue rewrite agent
# DASHSCOPE_API_KEY / DASHSCOPE_BASE_URL can stay in ../WorkShop/.env
PUSH_REWRITE_ENABLED=1
PUSH_REWRITE_MODEL=qwen-plus
PUSH_REWRITE_TEMPERATURE=0.7

# WeChat Official Account publish
WECHAT_MP_ENABLE=0
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
WECHAT_MP_AUTHOR=AI趣闻萃取
WECHAT_MP_TIMEOUT=20
WECHAT_MP_OPEN_COMMENT=0
WECHAT_MP_FANS_COMMENT_ONLY=0
WECHAT_MP_DIGEST_MAX_BYTES=120
WECHAT_REWRITE_ENABLED=1
WECHAT_REWRITE_MODEL=qwen-plus
WECHAT_REWRITE_TEMPERATURE=0.7
WECHAT_MP_DRAFT_ONLY=0
WECHAT_MP_APPEND_ORIGINAL_LINK=1
WECHAT_MP_DEFAULT_COVER_1=
WECHAT_MP_DEFAULT_COVER_2=
WECHAT_MP_DEFAULT_COVER_3=

# Email digest channel
EMAIL_PUSH_ENABLE=0
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_SSL=1
EMAIL_SMTP_STARTTLS=0
EMAIL_SMTP_TIMEOUT=20
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=AI趣闻萃取
EMAIL_REPLY_TO=
EMAIL_SUBJECT_PREFIX=
EMAIL_STATIC_SUBSCRIBERS=
EMAIL_UNSUBSCRIBE_BASE_URL=
EMAIL_MAX_FAILURE_DETAILS=20
