# OSS
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_DOMAIN=https://your-domain.com

# DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Agent-Do
AGENT_DO_BASE_URL=http://agent-do:8000
AGENT_DO_DEFAULT_MODEL=sonnet
AGENT_DO_MAX_TURNS=8
AGENT_DATA_HOST_ROOT=/absolute/path/to/your/repo/Backend/Agent-Do/data
AGENT_DO_PORT=18000
WORKSHOP_PORT=5000
DOCKER_BIN_PATH=/usr/bin/docker
DOCKER_SOCK_PATH=/var/run/docker.sock
AGENT_DO_APT_MIRROR=https://mirrors.aliyun.com/debian
AGENT_DO_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
APP_RUNTIME_NPM_REGISTRY=https://registry.npmmirror.com

# Runtime / Preview
WORKSHOP_RUNTIME_ROOT=
WORKSHOP_PREVIEW_PUBLIC_HOST=

# Per-conversation sandbox
WORKSHOP_SANDBOX_NETWORK=workshop_sandbox
WORKSHOP_SANDBOX_BUILD_NETWORK=bridge
WORKSHOP_SANDBOX_RUNNER_IMAGE=node:22-bookworm-slim
WORKSHOP_SANDBOX_NODE_IMAGE=node:22-bookworm-slim
WORKSHOP_SANDBOX_STATIC_IMAGE=python:3.12-alpine
WORKSHOP_SANDBOX_MEMORY=1g
WORKSHOP_SANDBOX_CPUS=1.5
WORKSHOP_SANDBOX_PIDS=256
WORKSHOP_SANDBOX_IDLE_TTL_MS=900000
WORKSHOP_SANDBOX_MAX_CONTAINERS=6
