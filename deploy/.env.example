EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=AI趣闻萃取
EMAIL_REPLY_TO=
EMAIL_SUBJECT_PREFIX=
EMAIL_STATIC_SUBSCRIBERS=
EMAIL_UNSUBSCRIBE_BASE_URL=
EMAIL_MAX_FAILURE_DETAILS=20

# Agent-Do / Workshop
AGENT_DATA_HOST_ROOT=/root/Backend/Agent-Do/data
AGENT_DO_PORT=18000
WORKSHOP_PORT=5000
DOCKER_SOCK_PATH=/var/run/docker.sock
CLAUDE_DOCKER_IMAGE=claude-runtime:latest
DEFAULT_RUNTIME_PROFILE=aliyun
DEFAULT_CLAUDE_MODEL=sonnet
ALIYUN_ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic
ALIYUN_ANTHROPIC_API_KEY=
ALIYUN_ANTHROPIC_MODEL=qwen3-coder-next
AGENT_DO_BASE_URL=http://agent-do:8000
AGENT_DO_DEFAULT_MODEL=sonnet
