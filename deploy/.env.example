AGENT_DO_APT_MIRROR=https://mirrors.aliyun.com/debian
AGENT_DO_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
APP_RUNTIME_IMAGE=node:20-alpine
APP_RUNTIME_NPM_REGISTRY=https://registry.npmmirror.com
APP_RUNTIME_MEMORY=2g
APP_RUNTIME_CPUS=1
APP_RUNTIME_INTERNAL_PORT=3000
APP_RUNTIME_START_TIMEOUT_SECONDS=30
APP_RUNTIME_IDLE_TIMEOUT_SECONDS=3600
APP_RUNTIME_IDLE_SWEEP_SECONDS=120
CLAUDE_TIMEOUT_SECONDS=900
CLAUDE_MEMORY=2g
CLAUDE_CPUS=1
CLAUDE_IDLE_TIMEOUT_SECONDS=900
CLAUDE_IDLE_SWEEP_SECONDS=60
AGENTDO_ORPHAN_SWEEP_SECONDS=300
AGENT_SESSION_RETENTION_SECONDS=0
